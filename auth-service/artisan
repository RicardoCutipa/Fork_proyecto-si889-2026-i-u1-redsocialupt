#!/usr/bin/env php
<?php

$app = require __DIR__.'/bootstrap/app.php';

// Registrar servicios necesarios para comandos CLI
$app->register(Illuminate\Database\MigrationServiceProvider::class);

// Crear kernel de consola manualmente para Lumen
$kernel = new Laravel\Lumen\Console\Kernel($app);

$status = $kernel->handle(
    $input = new Symfony\Component\Console\Input\ArgvInput,
    new Symfony\Component\Console\Output\ConsoleOutput
);

$kernel->terminate($input, $status);

exit($status);
